{
  "name": "@lalss/bug-report-fab",
  "version": "0.5.0",
  "description": "Federated bug-report FAB for lalss apps. Click → form modal with html2canvas-pro snip, brand-customizable, submit logic injected by consumer. Federation source of truth.",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18 <20",
    "react-dom": ">=18 <20"
  },
  "dependencies": {
    "html2canvas-pro": "^1.5.8"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lalss-dev/bug-report-fab.git"
  },
  "keywords": [
    "bug-report",
    "fab",
    "snip",
    "html2canvas",
    "react"
  ],
  "license": "UNLICENSED"
}
